NODE_ENV=production
PORT=3000
LOG_LEVEL=info
JSON_BODY_LIMIT=100kb
API_TOKEN=replace-with-strong-token

# Safer default for first production boot. Switch to postgres by setting
# STORAGE_BACKEND=postgres and DATABASE_URL below.
STORAGE_BACKEND=json
DATA_DIR=./data
STORE_BACKUP_LIMIT=5

DEFAULT_EXECUTION_MODE=miguel
MIGUEL_DISPATCH_ORDER=oz,webhook,local
MIGUEL_LOCAL_FALLBACK=false

# External dispatch targets
# DISPATCH_WEBHOOK_URL=https://example.com/dispatch
# WARP_API_KEY=wk-...
# WARP_API_BASE=https://app.warp.dev
# OZ_ENVIRONMENT_ID=env_...

# Postgres (enable by setting STORAGE_BACKEND=postgres)
# DATABASE_URL=postgresql://user:password@host:5432/oz_teste
# DATABASE_SSL=true

AUTO_SYNC_INTERVAL_MS=5000
AUTO_SYNC_DISABLED=false
# NOTIFICATION_WEBHOOK_URL=https://example.com/task-events
