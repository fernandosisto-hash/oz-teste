# Core runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
JSON_BODY_LIMIT=100kb
# TRUST_PROXY=loopback

# Auth
# Required in production
API_TOKEN=change-me

# Storage
# STORAGE_BACKEND=json
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_SSL=false
# DATA_DIR=./data
# STORE_BACKUP_LIMIT=3

# Dispatch
# DEFAULT_EXECUTION_MODE=miguel
# DISPATCH_WEBHOOK_URL=https://example.com/dispatch
# WARP_API_KEY=wk-...
# WARP_API_BASE=https://app.warp.dev
# OZ_ENVIRONMENT_ID=env_...
# MIGUEL_DISPATCH_ORDER=oz,webhook,local
# MIGUEL_LOCAL_FALLBACK=true

# Sync / notifications
# AUTO_SYNC_INTERVAL_MS=5000
# AUTO_SYNC_DISABLED=false
# NOTIFICATION_WEBHOOK_URL=https://example.com/task-events

# Explicit file overrides
# TASKS_DATA_FILE=./data/tasks.json
# NOTIFICATIONS_DATA_FILE=./data/notifications.json
